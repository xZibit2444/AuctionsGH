{
    "inputs": [
        {
            "id": "supabase-access-token",
            "type": "promptString",
            "description": "Supabase Personal Access Token (from supabase.com/dashboard/account/tokens)",
            "password": true
        }
    ],
    "servers": {
        "supabase": {
            "command": "supabase",
            "args": [
                "mcp",
                "start"
            ],
            "env": {
                "SUPABASE_ACCESS_TOKEN": "${input:supabase-access-token}"
            }
        }
    }
}
